{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção de testes da API Raízes do Nordeste",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login válido",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"kelver@raizes.com\", \"senha\": \"Senha@123\"}"
            }
          }
        },
        {
          "name": "T02 - Sem token (401)",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/pedidos/",
            "header": []
          }
        },
        {
          "name": "T03 - Registrar usuário",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/registrar",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Cliente Teste\", \"email\": \"cliente@raizes.com\", \"senha\": \"Senha@123\", \"perfil\": \"CLIENTE\", \"consentimento_lgpd\": true}"
            }
          }
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "T04 - Criar produto",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/produtos/",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Carne de Sol\", \"descricao\": \"Carne de sol nordestina\", \"preco\": 35.90}"
            }
          }
        },
        {
          "name": "T05 - Listar produtos",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/produtos/",
            "header": []
          }
        },
        {
          "name": "T06 - Produto inexistente (404)",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/produtos/9999",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T07 - Criar pedido válido",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/pedidos/",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"unidade_id\": 1, \"canal_pedido\": \"APP\", \"itens\": [{\"produto_id\": 1, \"quantidade\": 1}], \"forma_pagamento\": \"MOCK\"}"
            }
          }
        },
        {
          "name": "T08 - Pedido estoque insuficiente (409)",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/pedidos/",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"unidade_id\": 1, \"canal_pedido\": \"TOTEM\", \"itens\": [{\"produto_id\": 1, \"quantidade\": 9999}], \"forma_pagamento\": \"MOCK\"}"
            }
          }
        },
        {
          "name": "T09 - Filtrar pedidos por canal",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:8000/pedidos/?canalPedido=APP",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ]
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "T10 - Processar pagamento mock",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/pagamentos/processar",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"pedido_id\": 1, \"forma_pagamento\": \"MOCK\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Erros",
      "item": [
        {
          "name": "T11 - Campo obrigatório ausente (422)",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"kelver@raizes.com\"}"
            }
          }
        },
        {
          "name": "T12 - Email inválido (422)",
          "request": {
            "method": "POST",
            "url": "http://127.0.0.1:8000/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"emailinvalido\", \"senha\": \"Senha@123\"}"
            }
          }
        }
      ]
    }
  ]
}